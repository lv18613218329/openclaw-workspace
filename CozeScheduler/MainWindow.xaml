<Window x:Class="CozeScheduler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="扣子定时调度器 - Coze Scheduler" 
        Height="800" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">
    <Window.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="🤖" FontSize="32" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="扣子定时调度器" 
                           FontSize="26" FontWeight="Bold" Foreground="#2D3748"/>
                <TextBlock Text="每天定时调用 Coze 智能体" 
                           FontSize="13" Foreground="#718096" Margin="0,2,0,0"/>
            </StackPanel>
            <Border x:Name="StatusBadge" Background="#E2E8F0" CornerRadius="12" 
                    Padding="12,5" Margin="20,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="TxtStatusBadge" Text="⏸ 已停止" 
                           FontSize="12" Foreground="#4A5568"/>
            </Border>
        </StackPanel>

        <!-- Coze 配置 -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="🔧 Coze 智能体配置" FontSize="16" FontWeight="Bold" 
                           Foreground="#2D3748" Margin="0,0,0,15"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Access Token：" 
                               VerticalAlignment="Center" Foreground="#4A5568"/>
                    <PasswordBox Grid.Row="0" Grid.Column="1" x:Name="TxtCozeToken" 
                                 Margin="0,0,0,12" PasswordChanged="TxtCozeToken_PasswordChanged"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Bot ID：" 
                               VerticalAlignment="Center" Foreground="#4A5568"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtCozeBotId" 
                             Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="查询内容：" 
                               VerticalAlignment="Center" Foreground="#4A5568"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtCozeQuery" 
                             Height="60" AcceptsReturn="True" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 定时配置 -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="⏰ 定时调度配置" FontSize="16" FontWeight="Bold" 
                           Foreground="#2D3748" Margin="0,0,0,15"/>
                
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="每天执行时间：" VerticalAlignment="Center" 
                               Foreground="#4A5568" Margin="0,0,10,0"/>
                    <ComboBox x:Name="CmbHour" Width="70" FontSize="14" SelectedIndex="8"/>
                    <TextBlock Text=" : " VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <ComboBox x:Name="CmbMinute" Width="70" FontSize="14" SelectedIndex="0"/>
                    <TextBlock x:Name="TxtNextRun" Text="" VerticalAlignment="Center" 
                               Foreground="#718096" Margin="30,0,0,0" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 操作按钮 -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="🎮 操作" FontSize="16" FontWeight="Bold" 
                           Foreground="#2D3748" Margin="0,0,0,15"/>
                
                <WrapPanel>
                    <Button x:Name="BtnStart" Content="▶ 启动定时任务" 
                            Style="{StaticResource PrimaryButton}" 
                            Click="BtnStart_Click" Margin="0,0,12,10"/>
                    <Button x:Name="BtnStop" Content="⏹ 停止定时任务" 
                            Style="{StaticResource DangerButton}" 
                            Click="BtnStop_Click" IsEnabled="False" Margin="0,0,12,10"/>
                    <Button x:Name="BtnTest" Content="🧪 手动触发一次" 
                            Style="{StaticResource SecondaryButton}" 
                            Click="BtnTest_Click" Margin="0,0,12,10"/>
                    <Button x:Name="BtnSave" Content="💾 保存配置" 
                            Style="{StaticResource WarningButton}" 
                            Click="BtnSave_Click"/>
                </WrapPanel>

                <!-- 状态显示 -->
                <Border Background="#F7FAFC" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="当前状态：" FontWeight="Bold" Foreground="#2D3748"/>
                            <TextBlock x:Name="TxtCurrentStatus" Text="就绪" Foreground="#4A5568" Margin="10,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="下次执行：" FontWeight="Bold" Foreground="#2D3748"/>
                            <TextBlock x:Name="TxtNextExecute" Text="--" Foreground="#4A5568" Margin="10,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 返回结果显示 -->
                <Border Background="#FFF9E6" CornerRadius="8" Padding="15" Margin="0,15,0,0" BorderBrush="#FFE0B2" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📥 智能体返回结果" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,8"/>
                        <TextBox x:Name="TxtResponse" Height="100" IsReadOnly="True" 
                                 TextWrapping="Wrap" AcceptsReturn="True" 
                                 VerticalScrollBarVisibility="Auto"
                                 Background="White" BorderBrush="#FFE0B2"
                                 FontFamily="Microsoft YaHei UI" FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- 执行历史 -->
        <Border Grid.Row="4" Style="{StaticResource CardBorder}" MaxHeight="200">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="📋 执行历史（最近15条）" FontSize="14" FontWeight="Bold" 
                           Foreground="#2D3748" Margin="0,0,0,10"/>
                
                <ListBox Grid.Row="1" x:Name="LstHistory" 
                         BorderThickness="1" BorderBrush="#E2E8F0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="3">
                                <TextBlock Text="{Binding Time, StringFormat='{}{0:MM-dd HH:mm:ss}'}" 
                                           Width="130" Foreground="#718096" FontSize="12"/>
                                <TextBlock Text="{Binding Type}" Width="80" FontWeight="SemiBold" 
                                           FontSize="12" Foreground="#2D3748"/>
                                <TextBlock Width="70" FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Result}" Value="成功">
                                                    <Setter Property="Foreground" Value="#38A169"/>
                                                    <Setter Property="Text" Value="✅ 成功"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Result}" Value="失败">
                                                    <Setter Property="Foreground" Value="#E53E3E"/>
                                                    <Setter Property="Text" Value="❌ 失败"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Result}" Value="跳过">
                                                    <Setter Property="Foreground" Value="#718096"/>
                                                    <Setter Property="Text" Value="⏭ 跳过"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Message}" Foreground="#A0AEC0" 
                                           FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="350"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 状态栏 -->
        <Border Grid.Row="5" Background="Transparent" Padding="0,5,0,0">
            <TextBlock x:Name="TxtStatus" Text="就绪" Foreground="#718096" FontSize="12"/>
        </Border>
    </Grid>
</Window>