<Window x:Class="ElectronicWhiteboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="智教平台" 
        Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F5F5">
    
    <Window.Resources>
        <!-- 基础按钮样式 -->
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        
        <!-- 一级菜单按钮样式 -->
        <Style x:Key="PrimaryToolButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Background" Value="#4A4A4A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="4,4,0,0" Padding="5,5">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="icon" Text="{TemplateBinding Tag}" 
                                           FontSize="18" HorizontalAlignment="Center" Foreground="White"/>
                                <TextBlock x:Name="text" Text="{TemplateBinding Content}" 
                                           FontSize="11" HorizontalAlignment="Center" Foreground="White" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5A5A5A"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="border" Property="Background" Value="#4A90D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 选中的一级菜单按钮样式 -->
        <Style x:Key="PrimaryToolButtonSelectedStyle" TargetType="Button" BasedOn="{StaticResource PrimaryToolButtonStyle}">
            <Setter Property="Tag" Value="Selected"/>
        </Style>
        
        <!-- 二级菜单按钮样式 -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Background" Value="#4A4A4A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5A5A5A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 学科选中按钮样式 -->
        <Style x:Key="SubjectSelectedStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="#4A90D9"/>
        </Style>
        
        <!-- 工具栏展开面板按钮样式 -->
        <Style x:Key="PanelButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Background" Value="#4A4A4A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                              TextBlock.TextAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5A5A5A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 颜色按钮样式 -->
        <Style x:Key="ColorButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="12" BorderThickness="2" BorderBrush="Transparent">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding}"/>
                            </Border.InputBindings>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 顶部栏工具按钮样式 -->
        <Style x:Key="TopToolButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4A90D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 模式切换按钮样式 -->
        <Style x:Key="ModeButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Background" Value="#4A4A4A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5A5A5A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 滑块样式 -->
        <Style x:Key="SliderStyle" TargetType="Slider">
            <Setter Property="Minimum" Value="1"/>
            <Setter Property="Maximum" Value="20"/>
            <Setter Property="Value" Value="3"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>   <!-- 顶部栏 -->
            <RowDefinition Height="*"/>    <!-- 主画布 -->
            <RowDefinition Height="180"/>  <!-- 底部工具栏 -->
        </Grid.RowDefinitions>
        
        <!-- ==================== 顶部栏 ==================== -->
        <Border Grid.Row="0" Background="#2D2D30">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 左侧：Logo和标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="15,0">
                    <TextBlock Text="智教平台" Foreground="White" FontSize="18" FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- 右侧：撤销、重做、设置、模式切换 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="15,0">
                    <!-- 撤销 -->
                    <Button x:Name="btnUndo" Style="{StaticResource TopToolButtonStyle}" 
                            ToolTip="撤销 (Ctrl+Z)" Click="OnUndo">
                        <TextBlock Text="↩" FontSize="20" Foreground="White"/>
                    </Button>
                    <!-- 重做 -->
                    <Button x:Name="btnRedo" Style="{StaticResource TopToolButtonStyle}" 
                            ToolTip="重做 (Ctrl+Y)" Click="OnRedo">
                        <TextBlock Text="↪" FontSize="20" Foreground="White"/>
                    </Button>
                    <!-- 设置 -->
                    <Button Style="{StaticResource TopToolButtonStyle}" ToolTip="设置" Margin="10,0,0,0">
                        <TextBlock Text="⚙" FontSize="18" Foreground="White"/>
                    </Button>
                    
                    <Rectangle Width="1" Fill="#555" Margin="15,10"/>
                    
                    <!-- 备课模式 -->
                    <Button x:Name="btnPrepMode" Style="{StaticResource ModeButtonStyle}" 
                            Content="备课" Click="OnModeChange" Tag="Prep"/>
                    <!-- 授课模式 -->
                    <Button x:Name="btnTeachMode" Style="{StaticResource ModeButtonStyle}" 
                            Content="授课" Click="OnModeChange" Tag="Teach"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- ==================== 主画布区域 ==================== -->
        <Grid Grid.Row="1">
            <!-- 手写层 + 图形层 -->
            <Border Margin="10" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <InkCanvas x:Name="inkCanvas" Background="White"/>
                    <Canvas x:Name="shapeCanvas" Background="Transparent"/>
                </Grid>
            </Border>
        </Grid>
        
        <!-- ==================== 底部工具栏 ==================== -->
        <Border Grid.Row="2" Background="#2D2D30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>   <!-- 一级菜单 -->
                    <RowDefinition Height="*"/>    <!-- 展开面板 -->
                </Grid.RowDefinitions>
                
                <!-- 一级菜单 -->
                <Border Grid.Row="0" Background="#333333">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" Margin="10,0">
                            <Button x:Name="btnPen" Style="{StaticResource PrimaryToolButtonStyle}" 
                                    Content="画笔" Tag="✏" Click="OnToolClick" ToolTip="画笔"/>
                            <Button x:Name="btnHighlighter" Style="{StaticResource PrimaryToolButtonStyle}" 
                                    Content="荧光笔" Tag="🖍" Click="OnToolClick" ToolTip="荧光笔"/>
                            <Button x:Name="btnEraser" Style="{StaticResource PrimaryToolButtonStyle}" 
                                    Content="橡皮擦" Tag="🧹" Click="OnToolClick" ToolTip="橡皮擦"/>
                            <Button x:Name="btnSelect" Style="{StaticResource PrimaryToolButtonStyle}" 
                                    Content="选择" Tag="⬚" Click="OnToolClick" ToolTip="选择"/>
                            <Button x:Name="btnText" Style="{StaticResource PrimaryToolButtonStyle}" 
                                    Content="文本" Tag="T" Click="OnToolClick" ToolTip="文本"/>
                            <Button x:Name="btnSmartPen" Style="{StaticResource PrimaryToolButtonStyle}" 
                                    Content="智能笔" Tag="✦" Click="OnToolClick" ToolTip="智能笔"/>
                            
                            <Rectangle Width="1" Fill="#555" Margin="10,10"/>
                            
                            <Button x:Name="btnDrawTools" Style="{StaticResource PrimaryToolButtonStyle}" 
                                    Content="绘图工具" Tag="📐" Click="OnToolClick" ToolTip="绘图工具"/>
                            <Button x:Name="btnSubjectTools" Style="{StaticResource PrimaryToolButtonStyle}" 
                                    Content="学科工具" Tag="🔬" Click="OnToolClick" ToolTip="学科工具"/>
                            <Button x:Name="btnPageManage" Style="{StaticResource PrimaryToolButtonStyle}" 
                                    Content="页面管理" Tag="📄" Click="OnToolClick" ToolTip="页面管理"/>
                            <Button x:Name="btnResource" Style="{StaticResource PrimaryToolButtonStyle}" 
                                    Content="资源" Tag="🖼" Click="OnToolClick" ToolTip="资源"/>
                            <Button x:Name="btnMore" Style="{StaticResource PrimaryToolButtonStyle}" 
                                    Content="更多" Tag="⋯" Click="OnToolClick" ToolTip="更多"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                
                <!-- 展开面板区域 -->
                <Border Grid.Row="1" Background="#333333">
                    <Grid>
                        <!-- 画笔/荧光笔 面板 -->
                        <StackPanel x:Name="penPanel" Visibility="Collapsed" Margin="15,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 颜色选择 -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,30,10">
                                    <TextBlock Text="颜色:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Style="{StaticResource ColorButtonStyle}" Background="#000000" Click="OnColorSelect" Tag="#000000"/>
                                    <Button Style="{StaticResource ColorButtonStyle}" Background="#FF0000" Click="OnColorSelect" Tag="#FF0000"/>
                                    <Button Style="{StaticResource ColorButtonStyle}" Background="#00FF00" Click="OnColorSelect" Tag="#00FF00"/>
                                    <Button Style="{StaticResource ColorButtonStyle}" Background="#0000FF" Click="OnColorSelect" Tag="#0000FF"/>
                                    <Button Style="{StaticResource ColorButtonStyle}" Background="#FFFF00" Click="OnColorSelect" Tag="#FFFF00"/>
                                    <Button Style="{StaticResource ColorButtonStyle}" Background="#FF00FF" Click="OnColorSelect" Tag="#FF00FF"/>
                                    <Button Style="{StaticResource ColorButtonStyle}" Background="#00FFFF" Click="OnColorSelect" Tag="#00FFFF"/>
                                    <Button Style="{StaticResource ColorButtonStyle}" Background="#FFFFFF" Click="OnColorSelect" Tag="#FFFFFF"/>
                                </StackPanel>
                                
                                <!-- 粗细选择 -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="粗细:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Slider x:Name="penSizeSlider" Style="{StaticResource SliderStyle}" 
                                            Minimum="1" Maximum="30" Value="3" ValueChanged="OnPenSizeChanged"/>
                                    <TextBlock x:Name="txtPenSize" Text="3px" Foreground="White" 
                                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                        
                        <!-- 橡皮擦 面板 -->
                        <StackPanel x:Name="eraserPanel" Visibility="Collapsed" Margin="15,10">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnEraserPoint" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="点擦除" Click="OnEraserModeChange" Tag="Point"/>
                                <Button x:Name="btnEraserStroke" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="圈擦除" Click="OnEraserModeChange" Tag="Stroke"/>
                                <Button x:Name="btnEraserClear" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="清空画布" Click="OnClearCanvas"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- 绘图工具 面板 -->
                        <StackPanel x:Name="drawToolsPanel" Visibility="Collapsed" Margin="15,10">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnLine" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="直线" Click="OnShapeToolClick" Tag="Line"/>
                                <Button x:Name="btnRay" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="射线" Click="OnShapeToolClick" Tag="Ray"/>
                                <Button x:Name="btnLineSegment" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="线段" Click="OnShapeToolClick" Tag="LineSegment"/>
                                <!-- 矩形按钮组：点击展开子菜单 -->
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="btnRect" Style="{StaticResource SecondaryButtonStyle}" 
                                            Content="矩形▼" Click="OnShapeToolClick" Tag="Rectangle"/>
                                    <Button x:Name="btnRectNormal" Style="{StaticResource SecondaryButtonStyle}" 
                                            Content="矩形" Click="OnShapeToolClick" Tag="Rectangle" Visibility="Collapsed"/>
                                    <Button x:Name="btnSquare" Style="{StaticResource SecondaryButtonStyle}" 
                                            Content="正方形" Click="OnShapeToolClick" Tag="Square" Visibility="Collapsed"/>
                                    <Button x:Name="btnRoundedRect" Style="{StaticResource SecondaryButtonStyle}" 
                                            Content="圆角矩形" Click="OnShapeToolClick" Tag="RoundedRect" Visibility="Collapsed"/>
                                </StackPanel>
                                <!-- 椭圆按钮组：点击展开子菜单 -->
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="btnEllipse" Style="{StaticResource SecondaryButtonStyle}" 
                                            Content="椭圆▼" Click="OnShapeToolClick" Tag="Ellipse"/>
                                    <Button x:Name="btnEllipseNormal" Style="{StaticResource SecondaryButtonStyle}" 
                                            Content="椭圆" Click="OnShapeToolClick" Tag="Ellipse" Visibility="Collapsed"/>
                                    <Button x:Name="btnCircle" Style="{StaticResource SecondaryButtonStyle}" 
                                            Content="圆" Click="OnShapeToolClick" Tag="Circle" Visibility="Collapsed"/>
                                </StackPanel>
                                <!-- 三角形按钮组：点击展开子菜单 -->
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="btnTriangle" Style="{StaticResource SecondaryButtonStyle}" 
                                            Content="三角形▼" Click="OnShapeToolClick" Tag="Triangle"/>
                                    <Button x:Name="btnTriangleNormal" Style="{StaticResource SecondaryButtonStyle}" 
                                            Content="一般三角形" Click="OnShapeToolClick" Tag="TriangleNormal" Visibility="Collapsed"/>
                                    <Button x:Name="btnTriangleIsosceles" Style="{StaticResource SecondaryButtonStyle}" 
                                            Content="等腰三角形" Click="OnShapeToolClick" Tag="TriangleIsosceles" Visibility="Collapsed"/>
                                    <Button x:Name="btnTriangleRight" Style="{StaticResource SecondaryButtonStyle}" 
                                            Content="直角三角形" Click="OnShapeToolClick" Tag="TriangleRight" Visibility="Collapsed"/>
                                </StackPanel>
                                <Button x:Name="btnArrow" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="箭头" Click="OnShapeToolClick" Tag="Arrow"/>
                                <Button x:Name="btnPolygon" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="多边形" Click="OnShapeToolClick" Tag="Polygon"/>
                            </StackPanel>
                            <!-- 布尔运算子面板 -->
                            <StackPanel x:Name="booleanOpPanel" Orientation="Horizontal" Margin="0,5,0,0" Visibility="Collapsed">
                                <TextBlock Text="布尔运算:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Button x:Name="btnBooleanUnion" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="并集" Click="OnBooleanOperationClick" Tag="Union" ToolTip="合并两个图形"/>
                                <Button x:Name="btnBooleanIntersect" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="交集" Click="OnBooleanOperationClick" Tag="Intersection" ToolTip="保留重叠部分"/>
                                <Button x:Name="btnBooleanDifference" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="差集" Click="OnBooleanOperationClick" Tag="Difference" ToolTip="减去重叠部分"/>
                                <Button x:Name="btnBooleanXor" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="分割" Click="OnBooleanOperationClick" Tag="Xor" ToolTip="对称差集"/>
                            </StackPanel>
                            <!-- 矩形子菜单 -->
                            <StackPanel x:Name="rectSubMenu" Orientation="Horizontal" Margin="0,5,0,0" Visibility="Collapsed">
                                <Button x:Name="btnRectNormalSub" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="矩形" Click="OnShapeToolClick" Tag="Rectangle" ToolTip="普通矩形"/>
                                <Button x:Name="btnSquareSub" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="正方形" Click="OnShapeToolClick" Tag="Square" ToolTip="锁定宽高比的正方形"/>
                                <Button x:Name="btnRoundedRectSub" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="圆角矩形" Click="OnShapeToolClick" Tag="RoundedRect" ToolTip="带圆角的矩形"/>
                            </StackPanel>
                            <!-- 椭圆子菜单 -->
                            <StackPanel x:Name="ellipseSubMenu" Orientation="Horizontal" Margin="0,5,0,0" Visibility="Collapsed">
                                <Button x:Name="btnEllipseNormalSub" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="椭圆" Click="OnShapeToolClick" Tag="Ellipse" ToolTip="自由宽高比的椭圆"/>
                                <Button x:Name="btnCircleSub" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="圆" Click="OnShapeToolClick" Tag="Circle" ToolTip="锁定宽高比的圆"/>
                            </StackPanel>
                            <!-- 三角形子菜单 -->
                            <StackPanel x:Name="triangleSubMenu" Orientation="Horizontal" Margin="0,5,0,0" Visibility="Collapsed">
                                <Button x:Name="btnTriangleNormalSub" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="一般三角形" Click="OnShapeToolClick" Tag="TriangleNormal" ToolTip="任意三点确定的三角形"/>
                                <Button x:Name="btnTriangleIsoscelesSub" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="等腰三角形" Click="OnShapeToolClick" Tag="TriangleIsosceles" ToolTip="底边水平，两腰相等的三角形"/>
                                <Button x:Name="btnTriangleRightSub" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="直角三角形" Click="OnShapeToolClick" Tag="TriangleRight" ToolTip="有一个角是直角的三角形"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- 学科工具 面板 -->
                        <Grid x:Name="subjectToolsPanel" Visibility="Collapsed" Margin="15,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 学科选择 -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <Button x:Name="btnMath" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="数学" Click="OnSubjectSelect" Tag="Math"/>
                                <Button x:Name="btnPhysics" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="物理" Click="OnSubjectSelect" Tag="Physics"/>
                                <Button x:Name="btnChemistry" Style="{StaticResource SecondaryButtonStyle}" 
                                        Content="化学" Click="OnSubjectSelect" Tag="Chemistry"/>
                            </StackPanel>
                            
                            <!-- 学科工具内容 -->
                            <Border Grid.Row="1" Background="#404040" CornerRadius="4" Padding="10">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <WrapPanel x:Name="subjectToolsContent">
                                        <!-- 动态生成 -->
                                    </WrapPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                        
                        <!-- 页面管理 面板 -->
                        <StackPanel x:Name="pagePanel" Visibility="Collapsed" Margin="15,10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="新建页面" Click="OnNewPage"/>
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="复制页面" Click="OnCopyPage"/>
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="删除页面" Click="OnDeletePage"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtPageInfo" Text="当前: 1 / 1" Foreground="White" 
                                           VerticalAlignment="Center" Margin="0,0,20,0"/>
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="◀" Width="40" Click="OnPrevPage"/>
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="▶" Width="40" Click="OnNextPage"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- 资源 面板 -->
                        <StackPanel x:Name="resourcePanel" Visibility="Collapsed" Margin="15,10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="图片" Click="OnResourceClick" Tag="Image"/>
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="音频" Click="OnResourceClick" Tag="Audio"/>
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="视频" Click="OnResourceClick" Tag="Video"/>
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="背景" Click="OnResourceClick" Tag="Background"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- 更多 面板 -->
                        <StackPanel x:Name="morePanel" Visibility="Collapsed" Margin="15,10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="清空画布" Click="OnClearCanvas"/>
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="全屏模式" Click="OnFullScreen"/>
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="导出" Click="OnExport"/>
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="导入" Click="OnImport"/>
                            </StackPanel>
                            <CheckBox x:Name="chkSnap" Content="开启图形吸附" Foreground="White" 
                                      IsChecked="True" FontSize="13" Margin="0,0,0,5" Checked="OnSnapChanged" Unchecked="OnSnapChanged"/>
                            <CheckBox x:Name="chkGuideLine" Content="开启对齐辅助线" Foreground="White" 
                                      IsChecked="True" FontSize="13" Checked="OnGuideLineChanged" Unchecked="OnGuideLineChanged"/>
                        </StackPanel>
                        
                        <!-- 选择/文本/智能笔 面板（提示信息） -->
                        <TextBlock x:Name="toolHintPanel" Visibility="Collapsed" 
                                   Text="点击画布添加内容..." Foreground="#888" 
                                   FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>