<Window x:Class="GeometryUnfolding.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
        Title="几何展开动画 - Geometry Unfolding" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>
        
        <!-- 3D 视图区域 -->
        <helix:HelixViewport3D x:Name="Viewport3D" 
                              Grid.Column="0"
                              ZoomExtentsWhenLoaded="True"
                              Background="#1E1E1E">
            <!-- 灯光 -->
            <helix:SunLight/>
        </helix:HelixViewport3D>
        
        <!-- 控制面板 -->
        <Border Grid.Column="1" 
                Background="White" 
                Padding="15"
                BorderBrush="#E0E0E0"
                BorderThickness="1,0,0,0">
            <StackPanel>
                <TextBlock Text="几何形状" 
                          FontSize="18" 
                          FontWeight="Bold"
                          Margin="0,0,0,15"
                          Foreground="#333"/>
                
                <!-- 形状选择 -->
                <TextBlock Text="选择形状:" Margin="0,0,0,5" Foreground="#666"/>
                <ComboBox x:Name="ShapeComboBox" 
                         Margin="0,0,0,15"
                         Padding="10,8"
                         FontSize="14"
                         SelectedIndex="0">
                    <ComboBoxItem Content="立方体 (Cube)"/>
                    <ComboBoxItem Content="正四面体 (Tetrahedron)"/>
                    <ComboBoxItem Content="正八面体 (Octahedron)"/>
                    <ComboBoxItem Content="正十二面体 (Dodecahedron)"/>
                    <ComboBoxItem Content="正二十面体 (Icosahedron)"/>
                </ComboBox>
                
                <Separator Margin="0,10"/>
                
                <!-- 动画控制 -->
                <TextBlock Text="动画控制" 
                          FontSize="18" 
                          FontWeight="Bold"
                          Margin="0,10,0,15"
                          Foreground="#333"/>
                
                <StackPanel Orientation="Horizontal" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15">
                    <Button x:Name="UnfoldButton" 
                           Content="展开 ▶" 
                           Style="{StaticResource ModernButton}"
                           Width="90"
                           Click="UnfoldButton_Click"/>
                    <Button x:Name="FoldButton" 
                           Content="折叠 ◀" 
                           Style="{StaticResource ModernButton}"
                           Width="90"
                           Background="#4CAF50"
                           Click="FoldButton_Click"/>
                </StackPanel>
                
                <!-- 动画速度 -->
                <TextBlock Text="动画速度:" Margin="0,10,0,5" Foreground="#666"/>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="SpeedSlider" 
                           Minimum="0.5" 
                           Maximum="3" 
                           Value="1"
                           TickFrequency="0.5"
                           IsSnapToTickEnabled="True"
                           VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" 
                              Text="{Binding Value, StringFormat={}{0:F1}x, ElementName=SpeedSlider}"
                              Margin="10,0,0,0"
                              VerticalAlignment="Center"
                              Foreground="#666"/>
                </Grid>
                
                <Separator Margin="0,15"/>
                
                <!-- 视图控制 -->
                <TextBlock Text="视图控制" 
                          FontSize="18" 
                          FontWeight="Bold"
                          Margin="0,10,0,15"
                          Foreground="#333"/>
                
                <Button x:Name="ResetViewButton" 
                       Content="重置视角" 
                       Style="{StaticResource ModernButton}"
                       Background="#FF9800"
                       Click="ResetViewButton_Click"/>
                
                <Separator Margin="0,15"/>
                
                <!-- 状态信息 -->
                <TextBlock Text="状态" 
                          FontSize="18" 
                          FontWeight="Bold"
                          Margin="0,10,0,10"
                          Foreground="#333"/>
                
                <Border Background="#F5F5F5" 
                       Padding="10" 
                       CornerRadius="5"
                       Margin="0,0,0,10">
                    <TextBlock x:Name="StatusText" 
                              Text="就绪"
                              Foreground="#666"
                              TextWrapping="Wrap"/>
                </Border>
                
                <!-- 说明 -->
                <Border Background="#E3F2FD" 
                       Padding="10" 
                       CornerRadius="5"
                       Margin="0,10,0,0">
                    <TextBlock TextWrapping="Wrap" 
                              Foreground="#1565C0"
                              FontSize="12">
                        <Run Text="💡 提示:" FontWeight="Bold"/>
                        <LineBreak/>
                        • 点击并拖拽面可直接控制角度<LineBreak/>
                        • 鼠标左键拖动空白区旋转视角<LineBreak/>
                        • 鼠标滚轮缩放<LineBreak/>
                        • 右键拖动平移
                    </TextBlock>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>