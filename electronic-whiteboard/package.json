{
  "name": "electronic-whiteboard",
  "version": "1.0.0",
  "description": "教学用电子白板",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder"
  },
  "keywords": [
    "whiteboard",
    "education",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "katex": "^0.16.44",
    "konva": "^10.2.3",
    "polybooljs": "^1.2.2",
    "vue": "^3.5.31",
    "vue-konva": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.electronic.whiteboard",
    "productName": "ElectronicWhiteboard",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Education"
    },
    "deb": {
      "depends": [
        "gconf2",
        "gconf-service",
        "libnotify4",
        "libappindicator1",
        "libxtst6",
        "libnss3"
      ]
    },
    "rpm": {
      "depends": [
        "libnotify",
        "libappindicator",
        "libXtst",
        "nss"
      ]
    }
  }
}
