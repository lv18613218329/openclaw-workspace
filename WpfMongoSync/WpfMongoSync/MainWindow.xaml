<Window x:Class="WpfMongoSync.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MongoDB数据同步工具 - 飞书多维表格（增量同步）" 
        Height="850" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45a049"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#FF9800"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F57C00"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#f44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#d32f2f"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="🐾 MongoDB → 飞书多维表格 同步工具" 
                       FontSize="22" FontWeight="Bold" Foreground="#333"/>
            <TextBlock Text="（增量同步模式）" 
                       FontSize="14" Foreground="#FF9800" VerticalAlignment="Bottom" Margin="10,0,0,5"/>
        </StackPanel>

        <!-- 配置区域 -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- MongoDB配置 -->
                <GroupBox Grid.Row="0" Header="MongoDB 连接配置" FontWeight="Bold" Margin="0,0,0,10">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="连接字符串：" VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtMongoUrl" 
                                 Text="mongodb://readonly:5QDZ4SaF5Pias@frp.aixiaoyuan.cn:47017/"
                                 Margin="0,5" Padding="8" FontSize="13"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="数据库/集合：" VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,5">
                            <TextBox x:Name="TxtDatabase" Text="yn_collect" Width="150" Padding="8" FontSize="13" Margin="0,0,10,0"/>
                            <TextBlock Text="." VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="TxtCollection" Text="wjs_track_data" Width="150" Padding="8" FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- 查询条件 -->
                <GroupBox Grid.Row="1" Header="查询条件（增量同步按 events.local_time_ms 过滤）" FontWeight="Bold" Margin="0,0,0,10">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="事件类型：" VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtEvent" 
                                 Text="MQConfigError" Margin="0,5" Padding="8" FontSize="13"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="租户代码：" VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtTenantCode" 
                                 Text="" Margin="0,5" Padding="8" FontSize="13"/>
                    </Grid>
                </GroupBox>

                <!-- 飞书配置 -->
                <GroupBox Grid.Row="2" Header="飞书多维表格配置" FontWeight="Bold" Margin="0,0,0,10">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="App ID：" VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtAppId" 
                                 Text="" Margin="0,5" Padding="8" FontSize="13"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="App Secret：" VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="TxtAppSecret" 
                                     Margin="0,5" Padding="8" FontSize="13"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="多维表格：" VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,5">
                            <TextBox x:Name="TxtAppToken" Width="200" Padding="8" FontSize="13" Margin="0,0,10,0" Tag="App Token"/>
                            <TextBox x:Name="TxtTableId" Width="150" Padding="8" FontSize="13" Tag="Table ID"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Coze 智能体配置 -->
                <GroupBox Grid.Row="3" Header="Coze 智能体配置（同步完成后调用）" FontWeight="Bold">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Access Token：" VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <PasswordBox Grid.Row="0" Grid.Column="1" x:Name="TxtCozeToken" 
                                     Margin="0,5" Padding="8" FontSize="13"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Bot ID：" VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtCozeBotId" 
                                 Text="" Margin="0,5" Padding="8" FontSize="13"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="查询内容：" VerticalAlignment="Center" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtCozeQuery" 
                                 Text="查询 2026-01-01MQ 异常事件数量" Margin="0,5" Padding="8" FontSize="13"/>
                    </Grid>
                </GroupBox>
            </Grid>
        </Border>

        <!-- 数据展示区域 -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="查询结果" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtRecordCount" Text="(0 条记录)" 
                               Margin="10,0,0,0" Foreground="#666" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtSyncState" Text="尚未同步" 
                               Margin="20,0,0,0" Foreground="#FF9800" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="DataGrid" 
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="All"
                          AlternatingRowBackground="#F9F9F9"
                          HeadersVisibility="Column"
                          BorderThickness="1"
                          BorderBrush="#DDD">
                </DataGrid>
            </Grid>
        </Border>

        <!-- 操作按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button x:Name="BtnQuery" Content="🔍 查询全部" 
                    Style="{StaticResource PrimaryButton}" 
                    Click="BtnQuery_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnQueryRecent" Content="🕐 查询24小时" 
                    Style="{StaticResource SecondaryButton}" 
                    Click="BtnQueryRecent_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnSync" Content="📤 全量同步" 
                    Style="{StaticResource SecondaryButton}" 
                    Click="BtnSync_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnIncrementalSync" Content="➕ 增量同步" 
                    Style="{StaticResource AccentButton}" 
                    Click="BtnIncrementalSync_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnAutoSync" Content="⏰ 定时同步" 
                    Style="{StaticResource SecondaryButton}" 
                    Click="BtnAutoSync_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnStopAuto" Content="⏹ 停止定时" 
                    Style="{StaticResource DangerButton}" 
                    Click="BtnStopAuto_Click" IsEnabled="False" Margin="0,0,10,0"/>
            <Button x:Name="BtnResetSync" Content="🔄 重置状态" 
                    Style="{StaticResource DangerButton}" 
                    Click="BtnResetSync_Click"/>
        </StackPanel>

        <!-- 同步记录 -->
        <Border Grid.Row="4" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="100"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="📋 同步记录（最近10条）" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

                <ListBox Grid.Row="1" x:Name="LstSyncHistory" 
                         BorderThickness="1" BorderBrush="#DDD"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         MaxHeight="100">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="{Binding Time, StringFormat='{}{0:MM-dd HH:mm:ss}'}" 
                                           Width="110" Foreground="#666"/>
                                <TextBlock Text="{Binding Type}" Width="70" FontWeight="Bold"/>
                                <TextBlock Width="60">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Result}" Value="成功">
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                    <Setter Property="Text" Value="✅ 成功"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Result}" Value="失败">
                                                    <Setter Property="Foreground" Value="#f44336"/>
                                                    <Setter Property="Text" Value="❌ 失败"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Result}" Value="错误">
                                                    <Setter Property="Foreground" Value="#f44336"/>
                                                    <Setter Property="Text" Value="⚠️ 错误"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Result}" Value="无新数据">
                                                    <Setter Property="Foreground" Value="#FF9800"/>
                                                    <Setter Property="Text" Value="⚪ 无数据"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Count, StringFormat='{}{0}条'}" Width="50" Foreground="#333"/>
                                <TextBlock Text="{Binding Message}" Foreground="#999" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="5" Background="Transparent" Margin="0,5,0,0">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="就绪" Foreground="#666"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>